#!/bin/bash

set -xeuo pipefail

export HASS_TOKEN=$(cat ~/tower/spire/home-assistant-token)

state=$(curl -q -X GET \
      -H "Authorization: Bearer $HASS_TOKEN" \
      -H "Content-Type: application/json" \
      http://localhost:8123/api/states/input_boolean.gaming_mode | jq -r .state)

pid=

if [[ "$state" = on ]]; then
    exit
fi

curl -q -X POST \
      -H "Authorization: Bearer $HASS_TOKEN" \
      -H "Content-Type: application/json" \
      -d '{"entity_id": "input_boolean.gaming_mode"}' \
      http://localhost:8123/api/services/input_boolean/turn_on

for _ in {0..30}; do
    if pid=$(pgrep steamlink); then
        break
    fi
    sleep 1
done

tail --pid="$pid" -f /dev/null
jobs=$(jobs -p)
if [[ "$jobs" ]]; then
    kill "$jobs" || :
fi

curl -q -X POST \
      -H "Authorization: Bearer $HASS_TOKEN" \
      -H "Content-Type: application/json" \
      -d '{"entity_id": "input_boolean.gaming_mode"}' \
      http://localhost:8123/api/services/input_boolean/turn_off
