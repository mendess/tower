#!/bin/bash

set -euo pipefail

m() {
    /home/mendess/.local/share/cargo/bin/m "$@"
}

export HASS_TOKEN=$(cat ~/tower/spire/home-assistant-token)

tv-is-off() {
    state=$(curl -q -X GET \
      -H "Authorization: Bearer $HASS_TOKEN" \
      -H "Content-Type: application/json" \
      http://localhost:8123/api/states/media_player.aramanthinewall | jq .state -r)

    [[ "$state" != on ]]
}

if pgrep steamlink &>/dev/null; then
    exit
fi

curl -q -X POST http://localhost:8123/api/webhook/start_gaming_mode

while tv-is-off; do
    sleep 1
done

shyprctl l flatpak run com.valvesoftware.SteamLink

pid=
for _ in {0..10}; do
    if pid=$(pgrep steamlink); then
        break
    fi
    sleep 1
done

(
    tolaria=$(curl -q -X GET \
      -H "Authorization: Bearer $HASS_TOKEN" \
      -H "Content-Type: application/json" \
      http://localhost:8123/api/states/switch.wake_on_lan | jq .state -r)
    if [[ "$tolaria" != on ]]; then
        sleep 1m
    fi
    while [[ "$(m volume)" -gt 20 ]]; do
        m vd 2
        sleep 1
    done
    m vd 20
    m set-pause
    curl -X POST http://localhost:8123/api/webhook/set_tv_volume_25
) &

tail --pid="$pid" -f /dev/null
jobs=$(jobs -p)
if [[ "$jobs" ]]; then
    kill "$jobs" || :
fi

curl -q -X POST http://localhost:8123/api/webhook/set_tv_volume_10
m set-play
while [[ "$(m volume)" -lt 100 ]]; do
    m vu 5
    sleep 0.5
done
